---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import EpisodeCard from '../../../components/EpisodeCard.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  const categories = Array.from(
    new Set(episodes.flatMap((ep) => ep.data.categories))
  );
  return categories.map((category) => ({
    params: { category: category.toLowerCase() },
    props: { category },
  }));
}

const { category } = Astro.props;
const episodes = (await getCollection('episodes'))
  .filter((ep) => ep.data.categories.some((c) => c.toLowerCase() === category.toLowerCase()))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title={`Categoria: ${category}`} description={`Episodi nella categoria ${category}.`}>
  <div class="container section">
    <h1>Categoria: {category}</h1>
    <p class="count">{episodes.length} episodi</p>
    <div class="episode-grid">
      {episodes.map((episode) => (
        <EpisodeCard episode={episode} />
      ))}
    </div>
    <p class="back"><a href="/episodi/">&larr; Tutti gli episodi</a></p>
  </div>
</Base>

<style>
  .section {
    margin-top: 2rem;
  }
  .count {
    color: var(--muted);
  }
  .episode-grid {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }
  .back {
    margin-top: 1.5rem;
  }
</style>
